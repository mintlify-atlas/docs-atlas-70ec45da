  "keyFeatures": [
    "Lightweight state management with zero boilerplate",
    "Works with both vanilla JavaScript and React",
    "Selector-based subscriptions for fine-grained reactivity",
    "Persist middleware with localStorage/sessionStorage support and encryption",
    "Auto-revalidate on window focus",
    "Immutable internal state with deep equality checks",
    "Custom middleware support",
    "React 18 useSyncExternalStore integration"
